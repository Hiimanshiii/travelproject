<% layout("/layouts/boilerplate") %>

<div class="form-wrapper">
    <h2>Create a New Listing</h2>

    <form method="POST" action="/listings" class="listing-form needs-validation" novalidate enctype="multipart/form-data" >

        <div class="form-group">
            <label>Title</label>
            <input type="text"  class="form-control" name="listing[title]" placeholder="Add a catchy title" required>
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea  class="form-control" name="listing[description]" required></textarea>
        </div>

        <div class="form-group">
            <label>Image Link</label>
            <input type="text" name="listing[image]" placeholder="enter image URL/Link">
        </div>

        <div class="form-group">
            <label>Upload Image</label>
            <input type="file" name="listing[image]" >
        </div>

        <!-- Row for Price & Country -->
        <div class="row-group">
            <div class="form-group half">
                <label>Price</label>
                <input type="number" class="form-control" name="listing[price]" placeholder="1200" required>
            </div>

            <div class="form-group half">
                <label>Country</label>
                <input type="text" class="form-control" name="listing[country]" placeholder="India" required>
            </div>
        </div>

        <div class="form-group">
            <label>Location</label>
            <input type="text" class="form-control" name="listing[location]" placeholder="Jaipur, Rajasthan" required>
        </div>

        <button type="submit" class="submit-btn">Add</button>

    </form>
</div>